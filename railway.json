{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "preDeployCommand": "alembic upgrade head",
    "numReplicas": 1,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "sleepApplication": false,
    "restartPolicyType": "ALWAYS",
    "overlapSeconds": 0,
    "drainingSeconds": 15,
    "runtime": "V2"
  }
}
