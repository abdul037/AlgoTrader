# eToro Public API base URL from the official docs.
ETORO_BASE_URL=https://public-api.etoro.com
ETORO_REQUEST_MIN_INTERVAL_SECONDS=1.25
ETORO_RATE_LIMIT_COOLDOWN_SECONDS=300

# Public app API key from the eToro developer portal.
ETORO_API_KEY=your_public_key_here

# In the API docs this is sent as x-user-key. In the UI it appears under Generated Keys.
# This key is environment-specific. Use a Demo key with ETORO_ACCOUNT_MODE=demo.
ETORO_USER_KEY=your_generated_key_here

# Optional alias for the same generated key if you want the env name to match the UI wording.
# ETORO_GENERATED_KEY=

# Safe defaults.
ETORO_ACCOUNT_MODE=demo
ENABLE_REAL_TRADING=false
REQUIRE_APPROVAL=true

DATABASE_URL=sqlite:///./etoro_bot.db
MAX_RISK_PER_TRADE_PCT=1.0
MAX_DAILY_LOSS_USD=100
MAX_OPEN_POSITIONS=3
ALLOWED_INSTRUMENTS=NVDA,GOOG,GOOGL,AMD,MU,GOLD,CRWV
BLOCKED_INSTRUMENTS=OIL,NATGAS,SILVER
# Optional one-off reviewed exception:
# Only add CRWV temporarily if you explicitly intend to create a manually approved proposal.
# ALLOWED_INSTRUMENTS=NVDA,GOOG,GOOGL,AMD,MU,GOLD,CRWV
DEFAULT_EQUITY_LEVERAGE=1
MAX_EQUITY_LEVERAGE=5
MAX_GOLD_LEVERAGE=10
DEFAULT_TRADE_AMOUNT_USD=1000
PROPOSAL_EXPIRY_MINUTES=240
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
# Public HTTPS URL that Telegram can reach, for example:
# https://abc123.ngrok-free.app/telegram/webhook
TELEGRAM_WEBHOOK_URL=https://your-public-host/telegram/webhook
# Random shared secret used to validate Telegram webhook requests.
# Generate one with:
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret
TELEGRAM_ALLOWED_CHAT_IDS=your_telegram_chat_id
TELEGRAM_POLLING_ENABLED=false
TELEGRAM_POLL_INTERVAL_SECONDS=5
TELEGRAM_COMMAND_TIMEOUT_SECONDS=20
TELEGRAM_SCAN_DEFAULT_UNIVERSE_LIMIT=10
TELEGRAM_PROPOSE_TOP_DEFAULT_UNIVERSE_LIMIT=10
TELEGRAM_HOURLY_ALERTS_ENABLED=false
TELEGRAM_ALERT_INTERVAL_MINUTES=60
TELEGRAM_ALERT_SYMBOLS=NVDA
LIVE_SIGNAL_INTERVAL=OneDay
LIVE_SIGNAL_CANDLES_COUNT=250
LIVE_SIGNAL_TREND_WINDOW=100
LIVE_SIGNAL_PULLBACK_WINDOW=10
SIGNAL_SCAN_LIMIT=20
NOTIFY_ON_NONE_SIGNAL_CHANGE=true
SIGNAL_SCAN_UNIVERSE=NVDA,AMD,MU,GOOG,GOOGL,AAPL,MSFT,AMZN,META,AVGO,TSLA,CRM,ORCL,NFLX,TSM,ASML,SHOP,UBER,PLTR,INTC,SMCI,ARM,QCOM,ADBE,AMAT,PANW,CRWD,MRVL,ANET,LRCX
MARKET_UNIVERSE_NAME=top100_us
MARKET_UNIVERSE_TIER=broad_top100
MARKET_UNIVERSE_LIMIT=100
MARKET_UNIVERSE_SYMBOLS=
PRIMARY_MARKET_DATA_PROVIDER=auto
FALLBACK_MARKET_DATA_PROVIDER=none
MARKET_DATA_CACHE_DIR=.cache/market_data
MARKET_DATA_CACHE_TTL_SECONDS=900
REQUIRE_VERIFIED_MARKET_DATA_FOR_ALERTS=true
REQUIRE_PRIMARY_PROVIDER_FOR_ALERTS=true
REQUIRE_DIRECT_QUOTE_FOR_ALERTS=true
REQUIRE_UNCACHED_MARKET_DATA_FOR_ALERTS=false
MAX_MARKET_DATA_AGE_SECONDS=120
SCREENER_DEFAULT_TIMEFRAMES=15m,1h,1d
SCREENER_INTRADAY_TIMEFRAMES=1m,5m,15m
INTELLIGENT_SCAN_TIMEFRAMES=5m,15m,1h,1d
SINGLE_SYMBOL_ANALYSIS_TIMEFRAMES=1m,5m,15m,1h,1d
SCREENER_ACTIVE_STRATEGY_NAMES=rsi_vwap_ema_confluence
SCREENER_PRIMARY_STRATEGY_NAME=rsi_vwap_ema_confluence
SCREENER_TOP_K=20
SCREENER_MIN_CONFIDENCE=0.45
SCREENER_SCHEDULER_ENABLED=false
WORKFLOW_SCAN_DEFAULT_UNIVERSE_LIMIT=10
SCHEDULE_TIMEZONE=America/New_York
INTELLIGENT_SCAN_ENABLED=true
INTELLIGENT_SCAN_START_LOCAL=09:45
INTELLIGENT_SCAN_END_LOCAL=15:45
INTELLIGENT_SCAN_INTERVAL_MINUTES=120
PREMARKET_SCAN_ENABLED=true
PREMARKET_SCAN_TIME_LOCAL=08:30
MARKET_OPEN_SCAN_ENABLED=true
MARKET_OPEN_SCAN_TIME_LOCAL=09:35
INTRADAY_REPEATED_SCAN_ENABLED=false
INTRADAY_SCAN_START_LOCAL=10:00
INTRADAY_SCAN_END_LOCAL=15:30
END_OF_DAY_SCAN_ENABLED=true
END_OF_DAY_SCAN_TIME_LOCAL=15:50
WORKFLOW_LOCK_TIMEOUT_MINUTES=45
SWING_SCAN_INTERVAL_MINUTES=60
INTRADAY_SCAN_INTERVAL_MINUTES=15
OPEN_SIGNAL_CHECK_INTERVAL_MINUTES=5
DAILY_SUMMARY_HOUR_UTC=20
TRACK_ALERTED_SIGNALS=true
REQUIRE_BACKTEST_VALIDATION_FOR_ALERTS=true
MIN_BACKTEST_TRADES_FOR_ALERTS=10
MIN_BACKTEST_PROFIT_FACTOR=1.2
MIN_BACKTEST_ANNUALIZED_RETURN_PCT=5
MAX_BACKTEST_DRAWDOWN_PCT=35
SCREENER_WEAK_BACKTEST_ACTION=watchlist
SCREENER_ALERT_MODE=digest
SCREENER_TOP_ALERTS_PER_RUN=5
SCREENER_MIN_FINAL_SCORE_TO_ALERT=65
SCREENER_DUPLICATE_ALERT_WINDOW_MINUTES=240
SCREENER_MIN_SCORE_IMPROVEMENT_FOR_REPEAT=6
SCREENER_MIN_PRICE=5
SCREENER_MAX_PRICE=10000
SCREENER_MIN_LAST_VOLUME=250000
SCREENER_MIN_AVERAGE_VOLUME=750000
SCREENER_MIN_AVERAGE_DOLLAR_VOLUME=20000000
SCREENER_MAX_SPREAD_BPS=50
SCREENER_SCALP_MIN_CONFIDENCE=0.72
SCREENER_SCALP_MIN_RELATIVE_VOLUME=1.25
SCREENER_SCALP_MAX_SPREAD_BPS=18
SCREENER_MIN_ATR_PCT=0.35
SCREENER_MAX_ATR_PCT=8.5
SCREENER_MIN_TREND_STRENGTH_PCT=0.25
SCREENER_MIN_EFFICIENCY_RATIO=0.22
SCREENER_MIN_REWARD_TO_RISK=1.4
SCREENER_MIN_INDICATOR_CONFLUENCE=0.45
SCREENER_MIN_EXECUTION_QUALITY=0.5
SCREENER_MIN_ACCURACY_SCORE=0.52
SCREENER_MIN_CONFIRMATION_SCORE=0.45
SCREENER_MAX_FALSE_POSITIVE_RISK=0.68
SCREENER_MIN_RESISTANCE_ATR_DISTANCE=0.35
SCREENER_MAX_LATE_ENTRY_ATR_MULTIPLE=2.4
SCREENER_SCORE_WEIGHT_SETUP_QUALITY=18
SCREENER_SCORE_WEIGHT_TREND_STRENGTH=12
SCREENER_SCORE_WEIGHT_MOMENTUM_CONFIRMATION=10
SCREENER_SCORE_WEIGHT_LIQUIDITY_QUALITY=10
SCREENER_SCORE_WEIGHT_VOLATILITY_SUITABILITY=8
SCREENER_SCORE_WEIGHT_REWARD_TO_RISK=10
SCREENER_SCORE_WEIGHT_EXECUTION_QUALITY=8
SCREENER_SCORE_WEIGHT_INDICATOR_CONFLUENCE=10
SCREENER_SCORE_WEIGHT_ACCURACY_QUALITY=12
SCREENER_SCORE_WEIGHT_MARKET_REGIME=10
SCREENER_SCORE_WEIGHT_HIGHER_TIMEFRAME_ALIGNMENT=10
SCREENER_SCORE_WEIGHT_RELATIVE_STRENGTH_MARKET=8
SCREENER_SCORE_WEIGHT_RELATIVE_STRENGTH_SECTOR=6
SCREENER_SCORE_WEIGHT_TIME_OF_DAY=4
SCREENER_SCORE_WEIGHT_SIGNAL_FRESHNESS=4
SCREENER_SCORE_WEIGHT_BACKTEST_WIN_RATE=8
SCREENER_SCORE_WEIGHT_BACKTEST_PROFIT_FACTOR=10
SCREENER_SCORE_WEIGHT_BACKTEST_SAMPLE_SIZE=6
SCREENER_SCORE_WEIGHT_BACKTEST_RECENT_CONSISTENCY=8
SCREENER_SCORE_WEIGHT_BACKTEST_CREDIBILITY=8
SCREENER_SCORE_WEIGHT_REGIME_ALIGNMENT=10
CONFLUENCE_MINIMUM_SCORE=0.84
CONFLUENCE_MINIMUM_RELATIVE_VOLUME=1.25
CONFLUENCE_MINIMUM_ADX=20
CONFLUENCE_RSI_LONG_MIN=54
CONFLUENCE_RSI_LONG_MAX=66
CONFLUENCE_RSI_SHORT_MIN=34
CONFLUENCE_RSI_SHORT_MAX=46
CONFLUENCE_MAX_EXTENSION_ATR=1.6
CONFLUENCE_MIN_BODY_TO_RANGE=0.32
CONFLUENCE_MIN_CLOSE_LOCATION=0.62
EXECUTION_MODE=paper
EXECUTION_QUEUE_ENABLED=true
EXECUTION_RECHECK_QUOTE_BEFORE_ORDER=true
EXECUTION_MAX_ENTRY_DRIFT_BPS=35
PAPER_TRADING_ENABLED=true
PAPER_ACCOUNT_BALANCE_USD=100000
PAPER_SLIPPAGE_BPS=3
PAPER_MAX_HOLD_MINUTES_SCALP=90
PAPER_MAX_HOLD_MINUTES_INTRADAY=480
PAPER_MAX_HOLD_DAYS_SWING=20
LEDGER_ENABLED=true
LEDGER_RECORD_ALERTS_ENABLED=true
LEDGER_CYCLE_ENABLED=true
LEDGER_CYCLE_INTERVAL_MINUTES=15
LEDGER_MATCH_WINDOW_MINUTES=120
LEDGER_PENDING_EXPIRY_HOURS=48
# Optional: auto-import new manual eToro positions into the ledger.
# This is read-only and does not place, close, or modify trades.
LEDGER_TRACK_MANUAL_POSITIONS_ENABLED=false
MODEL_DEPLOYMENT_MODE=shadow
META_MODEL_PATH=
MAX_WEEKLY_LOSS_USD=300
PER_SYMBOL_POSITION_LIMIT=1
MAX_CONSECUTIVE_LOSSES_BEFORE_COOLDOWN=2
KILL_SWITCH_ENABLED=false
