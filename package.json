{
  "name": "algo-trader",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix frontend\" \"npm run dev:backend\"",
    "dev:backend": "backend/.venv/bin/python -m uvicorn app.main:app --app-dir backend",
    "dev:backend:reload": "backend/.venv/bin/python -m uvicorn app.main:app --reload --reload-dir backend/app --app-dir backend",
    "build": "npm run build --prefix frontend",
    "lint": "npm run lint --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
